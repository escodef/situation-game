{
    "name": "situation-game",
    "version": "1.0.0",
    "description": "",
    "homepage": "https://github.com/escodef/situation-game#readme",
    "bugs": {
        "url": "https://github.com/escodef/situation-game/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/escodef/situation-game.git"
    },
    "license": "ISC",
    "author": "kostya",
    "main": "src/index.ts",
    "scripts": {
        "build": "bun build src/index.ts --target bun --outdir ./dist",
        "start:dev": "bun --watch --inspect src/index.ts",
        "start": "NODE_ENV=production bun dist/index.js",
        "lint": "bunx biome lint --write",
        "lint:check": "bunx biome lint",
        "format": "bunx biome format --write",
        "format:check": "bunx biome format",
        "db:migrate": "bun ./src/database/migrate.ts",
        "asyncapi:generate": "bun asyncapi generate fromTemplate asyncapi.yaml @asyncapi/html-template -o ./docs --force-write"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1029.0",
        "@elysiajs/cron": "^1.4.1",
        "@elysiajs/openapi": "^1.4.14",
        "@elysiajs/static": "^1.4.7",
        "elysia": "^1.4.28",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.20.0"
    },
    "devDependencies": {
        "@asyncapi/cli": "^6.0.0",
        "@asyncapi/html-template": "^3.5.6",
        "@biomejs/biome": "^2.4.11",
        "@types/bun": "^1.3.12",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/pg": "^8.20.0",
        "bun-types": "^1.3.12",
        "typescript": "^6.0.2"
    }
}
